# Environment Variables — copy to .env and fill in real values

APP_ENV=development
LOG_LEVEL=debug

# PostgreSQL — t02-dev-pg
DATABASE_URL=postgresql://user:password@t02-dev-pg.postgres.database.azure.com:5432/dbname?sslmode=require

# Azure credentials (set by CI/CD — do not commit real values)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group
